# Server-only (do NOT expose to browser)
# Neon Postgres connection string
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DB?sslmode=require

# JWT signing secret (must match middleware + API routes)
JWT_SECRET=your_super_secret_jwt_key_here_must_be_at_least_32_characters_long

# Optional (defaults to 7d)
JWT_EXPIRES_IN=7d

# Optional: Google OAuth (works on Vercel + local)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Local dev (Next runs on 3000 by default; change if needed)
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback